# 🚀 KNOUX FINDR Authentication Environment Variables
# Copy this file to .env and fill in your OAuth credentials

# 🔧 Server Configuration
NODE_ENV=development
AUTH_PORT=3001
HOST=localhost
SESSION_SECRET=your_super_secure_session_secret_here

# 🟢 Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ⚫ GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# 🔵 Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# 📝 Instructions:
# 1. Google: https://console.developers.google.com/
#    - Create project → Enable Google+ API → Create OAuth credentials
#    - Authorized redirect URI: http://localhost:3001/auth/google/callback

# 2. GitHub: https://github.com/settings/applications/new
#    - Application name: KNOUX FINDR
#    - Homepage URL: http://localhost:3001
#    - Authorization callback URL: http://localhost:3001/auth/github/callback

# 3. Facebook: https://developers.facebook.com/apps/
#    - Create App → Settings → Basic
#    - Valid OAuth Redirect URI: http://localhost:3001/auth/facebook/callback
