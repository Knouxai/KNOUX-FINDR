# Environment Configuration for KNOUX FINDR Auth Server
NODE_ENV=development
PORT=3001
HOST=localhost

# Database
DATABASE_URL="file:./dev.db"

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_minimum_64_characters_long
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
CLIENT_URL=http://localhost:3000

# Session Secret
SESSION_SECRET=your_super_secure_session_secret_key_minimum_64_characters_long

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Apple OAuth (Optional)
APPLE_CLIENT_ID=com.knouxfindr.app
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=./apple-key.p8

# Microsoft OAuth (Optional)
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT=common

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# Logging
LOG_LEVEL=info
