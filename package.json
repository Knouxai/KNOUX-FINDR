{
  "name": "knoux-findr",
  "version": "1.0.0",
  "description": "KNOUX FINDR - Desktop AI-Powered File Search Engine",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run build:watch\"",
    "server": "node server.js",
    "auth-server": "node auth-server.js",
    "dev-full": "concurrently \"npm run server\" \"npm run auth-server\" \"npm run build:watch\"",
    "build": "webpack --mode production",
    "build:watch": "webpack --mode development --watch",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run build:watch\" \"wait-on dist/index.html && electron .\"",
    "electron-build": "npm run build && electron .",
    "package": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "search",
    "files",
    "local",
    "react",
    "electron",
    "ai",
    "desktop"
  ],
  "author": "KNOUX FINDR Team",
  "license": "ISC",
  "build": {
    "appId": "com.knouxfindr.app",
    "productName": "KNOUX FINDR",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "chokidar": "^3.5.3",
    "chrono-node": "^2.7.5",
    "compromise": "^14.11.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "electron": "^28.1.3",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "franc": "^6.1.0",
    "fs-extra": "^11.2.0",
    "fuse.js": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "mime-types": "^2.1.35",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "node-nlp": "^4.27.0",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.2",
    "passport-azure-ad": "^4.3.5",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-microsoft": "^2.1.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "redis": "^4.6.12",
    "sharp": "^0.33.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "vis-timeline": "^7.7.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.8.1",
    "electron-builder": "^24.9.1",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
