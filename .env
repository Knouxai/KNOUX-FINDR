# Environment Configuration for KNOUX FINDR Auth Server
NODE_ENV=development
PORT=3001
HOST=localhost

# Database
DATABASE_URL="file:./dev.db"

# JWT Configuration - استخدم مفاتيح قوية في الإنتاج
JWT_SECRET=knoux_super_secure_jwt_secret_key_for_development_minimum_64_chars
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
CLIENT_URL=http://localhost:3000

# Session Secret - استخدم مفتاح قوي في الإنتاج
SESSION_SECRET=knoux_super_secure_session_secret_key_for_development_minimum_64

# Google OAuth - أضف بياناتك الحقيقية
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth - أضف بياناتك الحقيقية
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Facebook OAuth - أضف بياناتك الحقيقية
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Microsoft OAuth (اختياري)
# MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
# MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
# MICROSOFT_TENANT=common

# Apple OAuth (اختياري)
# APPLE_CLIENT_ID=com.knouxfindr.app
# APPLE_TEAM_ID=your_apple_team_id
# APPLE_KEY_ID=your_apple_key_id
# APPLE_PRIVATE_KEY_PATH=./apple-key.p8

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# Logging
LOG_LEVEL=info
